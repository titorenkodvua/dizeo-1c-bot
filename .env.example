TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ALLOWED_USER_IDS=123456789

# Укажите тот же протокол и хост, что работают в браузере (часто https://)
ONEC_BASE_URL=https://1cbot.example.com
ONEC_API_PATH=/1capi/hs/botapi
ONEC_USERNAME=admin
ONEC_PASSWORD=CHANGE_ME
# Секунды на запрос к 1С. После долгого простоя первый вызов может быть долгим (туннель, TLS, редирект).
ONEC_TIMEOUT=60
DEFAULT_LIMIT=10
